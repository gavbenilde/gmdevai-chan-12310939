* text=auto

# Force Unity files to LF
*.cs text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf

# Unity YAML files
*.unity text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.asset text eol=lf
*.meta text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.fbx binary
*.wav binary
*.mp3 binary